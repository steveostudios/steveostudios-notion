---
layout: base
title: "Marvel Movie Reviews"
permalink: "/marvel/index.html"
---

<div class="page marvel-reviews">
  <h3>Marvel Family Movie Reviews</h3>

  {% if marvelMovies and marvelMovies.movies and marvelMovies.movies.length > 0 %}
    {% if marvelMovies.stats %}
      <section class="marvel-stats" aria-label="Marvel stats">
        <h4>Marvel Stats</h4>
        <div class="marvel-stats__grid">
          {% for member in marvelMovies.members %}
            <div class="marvel-stats__member">
              <h5>{{ member }}</h5>
              <ol class="marvel-stats__top-list">
                {% for pick in marvelMovies.stats.memberTopMovies[member] %}
                  <li>
                    <span class="marvel-stats__title">{{ pick.title }}</span>
                    <span class="marvel-stats__rating">{{ pick.rating }}/10</span>
                  </li>
                {% else %}
                  <li class="marvel-stats__empty">No ratings yet</li>
                {% endfor %}
              </ol>
            </div>
          {% endfor %}

          <div class="marvel-stats__family">
            <h5>Top rated (family)</h5>
            {% if marvelMovies.stats.topFamilyMovie %}
              <p class="marvel-stats__family-pick">
                <span class="marvel-stats__title">{{ marvelMovies.stats.topFamilyMovie.title }}</span>
                <span class="marvel-stats__rating">{{ marvelMovies.stats.topFamilyMovie.rating }}/10</span>
              </p>
            {% else %}
              <p class="marvel-stats__empty">No family scores yet</p>
            {% endif %}

            {% if marvelMovies.stats.nextMovieSlug %}
              <button
                type="button"
                class="marvel-stats__next-btn"
                data-scroll-target="movie-{{ marvelMovies.stats.nextMovieSlug }}"
              >
                Scroll to next movie{% if marvelMovies.stats.nextMovieTitle %}: {{ marvelMovies.stats.nextMovieTitle }}{% endif %}
              </button>
            {% endif %}
          </div>
        </div>
      </section>
    {% endif %}

    <ul class="movie-list">
      {% for movie in marvelMovies.movies %}
        <li
          class="movie-card{% if marvelMovies.stats and movie.slug == marvelMovies.stats.nextMovieSlug %} movie-card--next{% endif %}"
          id="movie-{{ movie.slug }}"
        >
          <div class="poster-wrap">
            {% if movie.poster %}
              <img src="{{ movie.poster }}" alt="{{ movie.title }} poster" class="poster" loading="lazy" />
            {% else %}
              <div class="poster-fallback">No poster</div>
            {% endif %}
          </div>

          <div class="movie-content">
            <div class="movie-header">
              <h4>{{ movie.title }}</h4>
              {% if movie.year %}
                <span>{{ movie.year }}</span>
              {% endif %}
            </div>

            <div class="movie-meta">
              <div><strong>Movie Rating:</strong> {{ movie.movieRating or "TBD" }}</div>
              <div>
                <strong>IMDb:</strong> {{ movie.imdbRating or "TBD" }}
                {% if movie.familyScore %}
                  · <strong>Family Score:</strong> {{ movie.familyScore }} /10
                {% endif %}
              </div>
            </div>

            <table class="family-table" aria-label="{{ movie.title }} family reviews">
              <thead>
                <tr>
                  <th>Family Member</th>
                  <th>Date Watched</th>
                  <th>Rating (/10)</th>
                </tr>
              </thead>
              <tbody>
                {% for member in marvelMovies.members %}
                  {% set memberReview = movie.reviews[member] %}
                  <tr>
                    <td>{{ member }}</td>
                    <td>{{ memberReview.watched if memberReview else "" }}</td>
                    <td>
                      {% if memberReview and memberReview.rating %}
                        {{ memberReview.rating }}
                      {% endif %}
                    </td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        </li>
      {% endfor %}
    </ul>
  {% else %}
    <p>Set `NOTION_DB_MARVEL_MOVIES` to load Marvel movie review data.</p>
  {% endif %}
</div>

<script>
  (function () {
    const btn = document.querySelector(".marvel-stats__next-btn");
    if (!btn) return;
    btn.addEventListener("click", () => {
      const targetId = btn.getAttribute("data-scroll-target");
      const target = targetId ? document.getElementById(targetId) : null;
      if (target) {
        target.scrollIntoView({ behavior: "smooth", block: "start" });
      }
    });
  })();
</script>
