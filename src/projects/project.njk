---
layout: base
pagination:
    data: projects
    size: 1
    alias: project
permalink: "/project/{{ project.slug }}/index.html"
---
<div class="page project">
    <h1>{{ project.title }}</h1>
    <div class="content">
      {% include "./../_includes/partials/project-slider.njk" %}
      {% include "./../_includes/partials/project-meta.njk" %}
      <article>
        {{ project.content | safe }}
      </article>
    </div>
  </div>
</div>
